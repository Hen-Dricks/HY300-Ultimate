# Copy to super-layout.env and replace every placeholder with values taken
# from the original image's `lpdump` output.

DEVICE_SIZE=0
METADATA_SIZE=65536
METADATA_SLOTS=2
BLOCK_SIZE=4096
SUPER_NAME=super
GROUP_NAME=main
GROUP_SIZE=0
SPARSE_OUTPUT=true

# Space-separated logical partition names.
PARTITIONS="system vendor product odm"

# Per-partition values. Sizes are bytes and must fit the corresponding images.
PART_system_SIZE=0
PART_system_ATTR=readonly
PART_vendor_SIZE=0
PART_vendor_ATTR=readonly
PART_product_SIZE=0
PART_product_ATTR=readonly
PART_odm_SIZE=0
PART_odm_ATTR=readonly
